# Copy to .env for local development:
#   cp .env.example .env

# PostgreSQL: LangChain uses postgresql+psycopg://… ; Supabase needs sslmode=require.
# Local:
CHAT_DB_URL=postgresql+psycopg://postgres:password@localhost:5432/dublinbikes
# Supabase example:
# CHAT_DB_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require

# DeepSeek API key (OpenAI-compatible API).
DEEPSEEK_API_KEY=

# Optional overrides
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
