# Copy to .env for local development:
#   cp .env.example .env

# PostgreSQL URL for LangChain SQLChatMessageHistory (message_store table).
CHAT_DB_URL=postgresql+psycopg://postgres:password@localhost:5432/dublinbikes

# DeepSeek API key (OpenAI-compatible API).
DEEPSEEK_API_KEY=

# Optional overrides
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
