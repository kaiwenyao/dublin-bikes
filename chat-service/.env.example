# Copy to .env for local development:
#   cp .env.example .env

# PostgreSQL URL for LangChain SQLChatMessageHistory (message_store table).
CHAT_DB_URL=postgresql+psycopg://postgres:password@localhost:5432/dublinbikes

# Alibaba Cloud DashScope (Qwen) OpenAI-compatible API key.
ALIYUN_API_KEY=

# Optional overrides
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
