# Copy to .env for local development:
#   cp .env.example .env

# Hugging Face Hub access token — required for the entrypoint to download
# bike_availability_model.pkl + model_features.pkl on container start.
# Skip download by leaving blank and dropping the .pkl files into MODEL_DIR yourself.
HF_TOKEN=

# Optional overrides
# HF_MODEL_REPO=ucdse/bike_availability_model
# MODEL_DIR=machine_learning
# MODEL_FILENAME=bike_availability_model.pkl
# FEATURES_FILENAME=model_features.pkl
