pipeline {
    agent {
        kubernetes {
            cloud 'kubernetes'
            defaultContainer 'python'
            yaml '''
apiVersion: v1
kind: Pod
metadata:
  labels:
    jenkins/label: prediction-service-build
spec:
  containers:
    - name: python
      image: python:3.12-slim
      command:
        - sleep
      args:
        - "9999999"
      tty: true
      workingDir: /home/jenkins/agent
      volumeMounts:
        - mountPath: /home/jenkins/.cache/pip
          name: pip-cache
    - name: docker
      image: docker:27-cli
      command:
        - sleep
      args:
        - "9999999"
      tty: true
      workingDir: /home/jenkins/agent
      volumeMounts:
        - mountPath: /var/run/docker.sock
          name: docker-sock
  volumes:
    - name: pip-cache
      emptyDir: {}
    - name: docker-sock
      hostPath:
        path: /var/run/docker.sock
'''
        }
    }

    parameters {
        string(name: 'IMAGE_NAME', defaultValue: 'kaiwenyao/dublin-bikes-prediction-service', description: 'Docker image name')
        string(name: 'IMAGE_TAG', defaultValue: '', description: 'Image tag override (empty means branch-gitHash-jBUILD_NUMBER, e.g. main-abc1234-j88)')
        booleanParam(name: 'PUSH_IMAGE', defaultValue: true, description: 'Push image to registry')
        booleanParam(name: 'DEPLOY_TO_SERVER', defaultValue: false, description: 'Deploy container to remote server')
        string(name: 'CONTAINER_NAME', defaultValue: 'dublin-bikes-prediction-service', description: 'Container name on remote server')
        string(name: 'CONTAINER_ENV_FILE', defaultValue: '/opt/dublin-bikes-prediction-service/.env', description: 'Env file path on remote server')
        string(name: 'DOCKER_NETWORK', defaultValue: 'dublin-bikes-network', description: 'Docker network for deployment')
        string(name: 'SSH_KEY_CREDENTIALS_ID', defaultValue: 'server-ssh-key', description: 'Jenkins SSH key credential ID')
    }

    environment {
        DOCKER_CREDENTIALS_ID = 'docker-hub-credentials'
        SERVER_HOST_CREDENTIALS_ID = 'hel-host'
        ENV_FILE_CREDENTIALS_ID = 'dublin-bikes-prediction-service.env'
        HF_TOKEN_CREDENTIALS_ID = 'huggingface-token'
    }

    stages {
        stage('1. Pull Code') {
            steps {
                checkout scm
            }
        }

        stage('Prediction Service CI') {
            when {
                anyOf {
                    changeset pattern: 'prediction-service/**'
                    triggeredBy 'UserIdCause'
                }
            }
            stages {
                stage('2. Python Syntax Check') {
                    steps {
                        container('python') {
                            dir('prediction-service') {
                                sh '''
                                python --version
                                python -m venv .venv
                                . .venv/bin/activate
                                pip install --upgrade pip
                                pip install -r requirements.txt
                                python -m py_compile main.py
                                pytest -q
                                '''
                            }
                        }
                    }
                }

                stage('3. Build & Push Docker Image') {
                    when {
                        not { changeRequest() }
                    }
                    steps {
                        container('docker') {
                            script {
                                def branch = (env.BRANCH_NAME ?: env.GIT_BRANCH ?: 'unknown')
                                    .replaceFirst(/^origin\//, '')
                                    .replaceAll('/', '-')
                                def gitHash = (env.GIT_COMMIT ?: '0000000').take(7)
                                def defaultTag = "${branch}-${gitHash}-j${env.BUILD_NUMBER}"
                                def finalTag = params.IMAGE_TAG?.trim() ? params.IMAGE_TAG.trim() : defaultTag
                                env.FULL_IMAGE = "${params.IMAGE_NAME}:${finalTag}"
                            }

                            withCredentials([
                                usernamePassword(
                                    credentialsId: env.DOCKER_CREDENTIALS_ID,
                                    usernameVariable: 'DOCKER_USER',
                                    passwordVariable: 'DOCKER_PASS'
                                )
                            ]) {
                                dir('prediction-service') {
                                    sh '''
                                    echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                                    docker build -t ${FULL_IMAGE} .
                                    if [ "${PUSH_IMAGE}" = "true" ] || [ "${DEPLOY_TO_SERVER}" = "true" ]; then
                                      docker push ${FULL_IMAGE}
                                    fi
                                    docker logout || true
                                    '''
                                }
                            }
                        }
                    }
                }

                stage('4. Deploy to Server') {
                    when {
                        expression {
                            def rawBranch = env.BRANCH_NAME ?: env.GIT_BRANCH ?: ''
                            def branch = rawBranch.replaceFirst(/^origin\//, '')
                            def isMain = branch == 'main'
                            def isPR = env.CHANGE_ID != null
                            def deployFlag = params.DEPLOY_TO_SERVER
                            echo "Deploy gate: branch='${branch}' (BRANCH_NAME='${env.BRANCH_NAME}', GIT_BRANCH='${env.GIT_BRANCH}'), isMain=${isMain}, isPR=${isPR}, DEPLOY_TO_SERVER=${deployFlag}"
                            return isMain && !isPR && deployFlag
                        }
                    }
                    environment {
                        CONTAINER_ENV_FILE = "${params.CONTAINER_ENV_FILE}"
                        DOCKER_NETWORK = "${params.DOCKER_NETWORK}"
                    }
                    steps {
                        container('docker') {
                            withCredentials([
                                string(credentialsId: env.SERVER_HOST_CREDENTIALS_ID, variable: 'SERVER_HOST'),
                                sshUserPrivateKey(credentialsId: params.SSH_KEY_CREDENTIALS_ID, keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER'),
                                usernamePassword(credentialsId: env.DOCKER_CREDENTIALS_ID, usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS'),
                                file(credentialsId: env.ENV_FILE_CREDENTIALS_ID, variable: 'ENV_FILE'),
                                string(credentialsId: env.HF_TOKEN_CREDENTIALS_ID, variable: 'HF_TOKEN')
                            ]) {
                                sh '''
                                if command -v apk >/dev/null 2>&1; then
                                  apk add --no-cache openssh-client bash
                                fi

                                # Create .env directory on remote server if it doesn't exist
                                ENV_DIR=$(dirname "${CONTAINER_ENV_FILE}")
                                ssh -i "${SSH_KEY}" -o StrictHostKeyChecking=no "${SSH_USER}@${SERVER_HOST}" "mkdir -p ${ENV_DIR}"

                                # Upload .env credential from Jenkins to the specified path on remote server
                                scp -i "${SSH_KEY}" -o StrictHostKeyChecking=no "${ENV_FILE}" "${SSH_USER}@${SERVER_HOST}:${CONTAINER_ENV_FILE}"

                                PASS_B64=$(printf '%s' "${DOCKER_PASS}" | base64)
                                USER_B64=$(printf '%s' "${DOCKER_USER}" | base64)
                                IMAGE_B64=$(printf '%s' "${FULL_IMAGE}" | base64)
                                NAME_B64=$(printf '%s' "${CONTAINER_NAME}" | base64)
                                ENV_FILE_B64=$(printf '%s' "${CONTAINER_ENV_FILE}" | base64)
                                NETWORK_B64=$(printf '%s' "${DOCKER_NETWORK}" | base64)
                                HF_TOKEN_B64=$(printf '%s' "${HF_TOKEN}" | base64)

                                ssh -i "${SSH_KEY}" -o StrictHostKeyChecking=no "${SSH_USER}@${SERVER_HOST}" \
                                "PASS_B64='${PASS_B64}' USER_B64='${USER_B64}' IMAGE_B64='${IMAGE_B64}' NAME_B64='${NAME_B64}' ENV_FILE_B64='${ENV_FILE_B64}' NETWORK_B64='${NETWORK_B64}' HF_TOKEN_B64='${HF_TOKEN_B64}' bash -s" <<'REMOTE'
set -e
DOCKER_PASS=$(echo "$PASS_B64" | base64 -d)
DOCKER_USER=$(echo "$USER_B64" | base64 -d)
FULL_IMAGE=$(echo "$IMAGE_B64" | base64 -d)
CONTAINER_NAME=$(echo "$NAME_B64" | base64 -d)
CONTAINER_ENV_FILE=$(echo "$ENV_FILE_B64" | base64 -d)
DOCKER_NETWORK=$(echo "$NETWORK_B64" | base64 -d)
HF_TOKEN=$(echo "$HF_TOKEN_B64" | base64 -d)

echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
docker pull "$FULL_IMAGE"
docker network inspect "$DOCKER_NETWORK" >/dev/null 2>&1 || docker network create --ipv6 "$DOCKER_NETWORK"
docker rm -f "$CONTAINER_NAME" || true
docker run -d \
  --name "$CONTAINER_NAME" \
  --restart unless-stopped \
  --network "$DOCKER_NETWORK" \
  -e TZ=UTC \
  -e HF_TOKEN="$HF_TOKEN" \
  --env-file "$CONTAINER_ENV_FILE" \
  "$FULL_IMAGE"
REMOTE
                                '''
                            }
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
