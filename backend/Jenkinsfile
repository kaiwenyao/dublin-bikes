pipeline {
    agent {
        kubernetes {
            cloud 'kubernetes'
            defaultContainer 'maven'
            yaml '''
apiVersion: v1
kind: Pod
metadata:
  labels:
    jenkins/label: dublin-bikes-backend-build
spec:
  containers:
    - name: maven
      image: maven:3.9-eclipse-temurin-21
      command:
        - sleep
      args:
        - "9999999"
      tty: true
      workingDir: /home/jenkins/agent
      volumeMounts:
        - mountPath: /home/jenkins/.m2
          name: maven-cache
    - name: docker
      image: docker:27-cli
      command:
        - sleep
      args:
        - "9999999"
      tty: true
      workingDir: /home/jenkins/agent
      volumeMounts:
        - mountPath: /var/run/docker.sock
          name: docker-sock
  volumes:
    - name: maven-cache
      emptyDir: {}
    - name: docker-sock
      hostPath:
        path: /var/run/docker.sock
'''
        }
    }

    parameters {
        string(name: 'IMAGE_NAME', defaultValue: 'kaiwenyao/dublin-bikes-backend', description: 'Docker image name')
        string(name: 'IMAGE_TAG', defaultValue: '', description: 'Image tag override (empty means branch-gitHash-jBUILD_NUMBER, e.g. main-abc1234-j88)')
        booleanParam(name: 'PUSH_IMAGE', defaultValue: true, description: 'Push image to registry')
        booleanParam(name: 'DEPLOY_TO_SERVER', defaultValue: false, description: 'Deploy container to remote server')
        string(name: 'CONTAINER_NAME', defaultValue: 'dublin-bikes-backend', description: 'Container name on remote server')
        string(name: 'CONTAINER_CONFIG_FILE', defaultValue: '/opt/dublin-bikes-backend/application-prod.yaml', description: 'Spring application-prod.yaml path on remote server')
        string(name: 'DOCKER_NETWORK', defaultValue: 'dublin-bikes-network', description: 'Docker network for deployment')
        string(name: 'SSH_KEY_CREDENTIALS_ID', defaultValue: 'server-ssh-key', description: 'Jenkins SSH key credential ID')
    }

    environment {
        DOCKER_CREDENTIALS_ID = 'docker-hub-credentials'
        SERVER_HOST_CREDENTIALS_ID = 'hel-host'
        CONFIG_FILE_CREDENTIALS_ID = 'dublin-bikes-backend-prod-yaml'
    }

    stages {
        stage('1. Pull Code') {
            steps {
                checkout scm
            }
        }

        stage('Backend CI') {
            when {
                anyOf {
                    changeset pattern: 'backend/**'
                    triggeredBy 'UserIdCause'
                }
            }
            stages {
                stage('2. Maven Compile') {
                    steps {
                        container('maven') {
                            dir('backend') {
                                sh '''
                                java -version
                                mvn -version
                                mvn -B -ntp -DskipTests compile
                                '''
                            }
                        }
                    }
                }

                stage('3. Run Tests') {
                    steps {
                        container('maven') {
                            dir('backend') {
                                sh '''
                                mvn -B -ntp test
                                '''
                            }
                        }
                    }
                    post {
                        always {
                            junit testResults: 'backend/target/surefire-reports/*.xml', allowEmptyResults: false
                        }
                    }
                }

                stage('4. Build & Push Docker Image') {
                    when {
                        not { changeRequest() }
                    }
                    steps {
                        container('docker') {
                            script {
                                def branch = (env.BRANCH_NAME ?: env.GIT_BRANCH ?: 'unknown')
                                    .replaceFirst(/^origin\//, '')
                                    .replaceAll('/', '-')
                                def gitHash = (env.GIT_COMMIT ?: '0000000').take(7)
                                def defaultTag = "${branch}-${gitHash}-j${env.BUILD_NUMBER}"
                                def finalTag = params.IMAGE_TAG?.trim() ? params.IMAGE_TAG.trim() : defaultTag
                                env.FULL_IMAGE = "${params.IMAGE_NAME}:${finalTag}"
                            }

                            withCredentials([
                                usernamePassword(
                                    credentialsId: env.DOCKER_CREDENTIALS_ID,
                                    usernameVariable: 'DOCKER_USER',
                                    passwordVariable: 'DOCKER_PASS'
                                )
                            ]) {
                                dir('backend') {
                                    sh '''
                                    echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                                    docker build -t ${FULL_IMAGE} .
                                    if [ "${PUSH_IMAGE}" = "true" ] || [ "${DEPLOY_TO_SERVER}" = "true" ]; then
                                      docker push ${FULL_IMAGE}
                                    fi
                                    docker logout || true
                                    '''
                                }
                            }
                        }
                    }
                }

                stage('5. Deploy to Server') {
                    when {
                        allOf {
                            branch 'main'
                            not { changeRequest() }
                            expression { return params.DEPLOY_TO_SERVER }
                        }
                    }
                    environment {
                        CONTAINER_CONFIG_FILE = "${params.CONTAINER_CONFIG_FILE}"
                        DOCKER_NETWORK = "${params.DOCKER_NETWORK}"
                    }
                    steps {
                        container('docker') {
                            withCredentials([
                                string(credentialsId: env.SERVER_HOST_CREDENTIALS_ID, variable: 'SERVER_HOST'),
                                sshUserPrivateKey(credentialsId: params.SSH_KEY_CREDENTIALS_ID, keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER'),
                                usernamePassword(credentialsId: env.DOCKER_CREDENTIALS_ID, usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS'),
                                file(credentialsId: env.CONFIG_FILE_CREDENTIALS_ID, variable: 'CONFIG_FILE')
                            ]) {
                                sh '''
                                if command -v apk >/dev/null 2>&1; then
                                  apk add --no-cache openssh-client bash
                                fi

                                CONFIG_DIR=$(dirname "${CONTAINER_CONFIG_FILE}")
                                ssh -i "${SSH_KEY}" -o StrictHostKeyChecking=no "${SSH_USER}@${SERVER_HOST}" "mkdir -p ${CONFIG_DIR}"

                                scp -i "${SSH_KEY}" -o StrictHostKeyChecking=no "${CONFIG_FILE}" "${SSH_USER}@${SERVER_HOST}:${CONTAINER_CONFIG_FILE}"
                                ssh -i "${SSH_KEY}" -o StrictHostKeyChecking=no "${SSH_USER}@${SERVER_HOST}" "chown 10001:10001 '${CONTAINER_CONFIG_FILE}' && chmod 0400 '${CONTAINER_CONFIG_FILE}'"

                                PASS_B64=$(printf '%s' "${DOCKER_PASS}" | base64)
                                USER_B64=$(printf '%s' "${DOCKER_USER}" | base64)
                                IMAGE_B64=$(printf '%s' "${FULL_IMAGE}" | base64)
                                NAME_B64=$(printf '%s' "${CONTAINER_NAME}" | base64)
                                CONFIG_FILE_B64=$(printf '%s' "${CONTAINER_CONFIG_FILE}" | base64)
                                NETWORK_B64=$(printf '%s' "${DOCKER_NETWORK}" | base64)

                                ssh -i "${SSH_KEY}" -o StrictHostKeyChecking=no "${SSH_USER}@${SERVER_HOST}" \
                                "PASS_B64='${PASS_B64}' USER_B64='${USER_B64}' IMAGE_B64='${IMAGE_B64}' NAME_B64='${NAME_B64}' CONFIG_FILE_B64='${CONFIG_FILE_B64}' NETWORK_B64='${NETWORK_B64}' bash -s" <<'REMOTE'
set -e
DOCKER_PASS=$(echo "$PASS_B64" | base64 -d)
DOCKER_USER=$(echo "$USER_B64" | base64 -d)
FULL_IMAGE=$(echo "$IMAGE_B64" | base64 -d)
CONTAINER_NAME=$(echo "$NAME_B64" | base64 -d)
CONTAINER_CONFIG_FILE=$(echo "$CONFIG_FILE_B64" | base64 -d)
DOCKER_NETWORK=$(echo "$NETWORK_B64" | base64 -d)

echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
docker pull "$FULL_IMAGE"
docker network inspect "$DOCKER_NETWORK" >/dev/null 2>&1 || docker network create "$DOCKER_NETWORK"
docker rm -f "$CONTAINER_NAME" || true
docker run -d \
  --name "$CONTAINER_NAME" \
  --restart unless-stopped \
  --network "$DOCKER_NETWORK" \
  -e TZ=UTC \
  -e SPRING_PROFILES_ACTIVE=prod \
  -e SPRING_CONFIG_ADDITIONAL_LOCATION=file:/config/ \
  -v "${CONTAINER_CONFIG_FILE}:/config/application-prod.yaml:ro" \
  "$FULL_IMAGE"
REMOTE
                                '''
                            }
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
